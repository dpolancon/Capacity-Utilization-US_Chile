\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces NRC survival profiles. These report-only profiles include the D06 baseline, the Nomura-office comparison, longer-life robustness cases, and shape checks.}}{4}{figure.3}\protected@file@percent }
