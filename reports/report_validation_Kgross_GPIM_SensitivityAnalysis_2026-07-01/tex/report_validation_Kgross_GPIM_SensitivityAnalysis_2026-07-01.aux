\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Real ME stock sensitivity. Report-only ME gross GPIM stocks are compared against the D06 baseline; no sensitivity stock is a source-of-truth replacement.}}{6}{figure.5}\protected@file@percent }
